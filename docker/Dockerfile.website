# Dockerfile for Main Website
# Build: docker build -f docker/Dockerfile.website -t adapt-shield-website .

FROM python:3.10-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    fastapi==0.104.1 \
    uvicorn==0.24.0 \
    httpx==0.25.2

COPY app/website.py ./app/website.py

EXPOSE 9000

CMD ["uvicorn", "app.website:app", "--host", "0.0.0.0", "--port", "9000"]